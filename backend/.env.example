# --- Environment -----------------------------------------------------
ENVIRONMENT=development
LOG_LEVEL=INFO

# --- Database ----------------------------------------------------------
# If using docker-compose with a `db` service, host is the service name,
# not localhost.
DATABASE_URL=postgresql://postgres:postgres@db:5432/lmh_rag
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT_SECONDS=30
DB_POOL_RECYCLE_SECONDS=1800

# --- Ollama --------------------------------------------------------------
#  is a host-gateway style IP for reaching the host's Ollama
# from inside a container (e.g. Docker Desktop). Adjust for your setup —
# on Linux you may need host.docker.internal or the actual host IP.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:latest
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
OLLAMA_EMBEDDING_DIM=768
OLLAMA_REQUEST_TIMEOUT_SECONDS=60.0
OLLAMA_GENERATE_TIMEOUT_SECONDS=120.0
OLLAMA_MAX_RETRIES=3
OLLAMA_RETRY_BACKOFF_SECONDS=1.0

# --- RAG pipeline -----------------------------------------------------
CHUNK_SIZE=500
CHUNK_OVERLAP=50
RETRIEVAL_TOP_K=3
MAX_UPLOAD_SIZE_MB=20

# --- Security ------------------------------------------------------------
# Leave blank for local dev (auth disabled on upload/delete).
# Set a real secret for staging/production.
API_KEY=

# Comma-separated. Add your frontend's dev/prod URL(s) here.
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# --- Rate limiting -----------------------------------------------------
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=60
RATE_LIMIT_WINDOW_SECONDS=60